<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Painel de filtros -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FILTROS"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/red_primary"
                android:layout_marginBottom="12dp"/>

            <!-- Filtro por Status -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textSize="13sp"
                android:textColor="@color/gray_text"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spinnerFiltroStatus"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"/>

            <!-- Filtro por Data Início -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Data Início (dd/MM/aaaa)"
                android:layout_marginBottom="10dp"
                app:endIconMode="custom"
                app:endIconDrawable="@android:drawable/ic_menu_my_calendar">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDataInicio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:cursorVisible="false"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Filtro por Data Fim -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Data Fim (dd/MM/aaaa)"
                android:layout_marginBottom="12dp"
                app:endIconMode="custom"
                app:endIconDrawable="@android:drawable/ic_menu_my_calendar">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDataFim"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:cursorVisible="false"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Botões -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAplicarFiltros"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="2"
                    android:text="@string/aplicar_filtros"
                    android:textStyle="bold"
                    app:backgroundTint="@color/red_primary"
                    app:cornerRadius="8dp"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLimparFiltros"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/limpar_filtros"
                    android:textColor="@color/red_primary"
                    app:strokeColor="@color/red_primary"
                    app:cornerRadius="8dp"/>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Contador de resultados -->
    <TextView
        android:id="@+id/tvResultados"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingBottom="4dp"
        android:text="Resultados: 0"
        android:textSize="13sp"
        android:textColor="@color/gray_text"/>

    <!-- Lista filtrada -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerFiltros"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingBottom="16dp"
        android:clipToPadding="false"/>

    <!-- Estado vazio -->
    <TextView
        android:id="@+id/tvVazioFiltros"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="32dp"
        android:text="Nenhum chamado encontrado com esses filtros."
        android:textSize="15sp"
        android:textColor="@color/gray_text"
        android:visibility="gone"/>

</LinearLayout>